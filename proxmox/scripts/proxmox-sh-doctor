#!/bin/sh
set -e
set -u

# proxmox-sh-doctor: validate proxmox-sh environment for agent use
#
# Checks dependencies, env file health, API connectivity, and token permissions.
# Run this BEFORE proxmox-sh-resources.
#
# Exit codes:
#   0 - all checks passed
#   1 - fatal: missing dependency or broken env
#   2 - warning: connectivity or API issue (env is valid)

g_exit_code=0
g_warnings=""
g_errors=""

fn_log_ok() {
	printf '  [OK] %s\n' "$1"
}

fn_log_warn() {
	printf '  [WARN] %s\n' "$1" >&2
	g_warnings="${g_warnings}${1}\n"
	if test "${g_exit_code}" -lt 2; then
		g_exit_code=2
	fi
}

fn_log_err() {
	printf '  [ERROR] %s\n' "$1" >&2
	g_errors="${g_errors}${1}\n"
	g_exit_code=1
}

fn_log_section() {
	echo ""
	echo "=== $1 ==="
}

# ----------------------------------------
# Section 1: Dependencies
# ----------------------------------------
fn_check_deps() {
	fn_log_section "Dependencies"

	# webi
	if command -v webi >/dev/null 2>&1; then
		fn_log_ok "webi installed"
	else
		fn_log_warn "webi not installed (curl https://webi.sh | sh)"
	fi

	# go
	if command -v go >/dev/null 2>&1; then
		b_go_version="$(go version | cut -d' ' -f3)"
		fn_log_ok "go installed (${b_go_version})"
	else
		fn_log_err "go not installed (webi go)"
	fi

	# jq (used by proxmox-create for API responses)
	if command -v jq >/dev/null 2>&1; then
		fn_log_ok "jq installed"
	else
		fn_log_err "jq not installed (webi jq)"
	fi

	# curl
	if command -v curl >/dev/null 2>&1; then
		fn_log_ok "curl installed"
	else
		fn_log_err "curl not installed"
	fi

	# ssh-pubkey (optional, used by proxmox-create for default keys)
	if command -v ssh-pubkey >/dev/null 2>&1; then
		fn_log_ok "ssh-pubkey installed"
	else
		fn_log_warn "ssh-pubkey not installed (webi ssh-pubkey) - proxmox-create will require explicit key path"
	fi
}

# ----------------------------------------
# Section 2: proxmox-sh installation
# ----------------------------------------
fn_check_proxmox_sh() {
	fn_log_section "proxmox-sh"

	if ! test -d ~/.local/opt/proxmox-sh/; then
		fn_log_err "proxmox-sh not installed at ~/.local/opt/proxmox-sh/"
		echo "  Install:"
		echo "    mkdir -p ~/.local/opt/"
		echo "    git clone https://github.com/therootcompany/proxmox-sh.git ~/.local/opt/proxmox-sh"
		return
	fi
	fn_log_ok "proxmox-sh installed at ~/.local/opt/proxmox-sh/"

	# Check it's in PATH
	if command -v proxmox-create >/dev/null 2>&1; then
		fn_log_ok "proxmox-create in PATH"
	else
		fn_log_warn "proxmox-create not in PATH"
		echo "  Fix:"
		# shellcheck disable=SC2016
		echo '    pathman add ~/.local/opt/proxmox-sh/bin'
	fi

	if command -v env-switch >/dev/null 2>&1; then
		fn_log_ok "env-switch in PATH"
	else
		fn_log_warn "env-switch not in PATH (same fix as above)"
	fi

	# Check config dir exists
	# shellcheck disable=SC2088
	if ! test -d ~/.config/proxmox-sh/; then
		fn_log_warn "~/.config/proxmox-sh/ does not exist - run: proxmox-sh-init"
		return
	fi
	# shellcheck disable=SC2088
	fn_log_ok "~/.config/proxmox-sh/ exists"
}

# ----------------------------------------
# Section 3: Environment files
# ----------------------------------------
fn_check_env_files() {
	fn_log_section "Environment Files"

	# shellcheck disable=SC2088
	if ! test -d ~/.config/proxmox-sh/; then
		fn_log_err "~/.config/proxmox-sh/ missing - run proxmox-sh-init first"
		return
	fi

	# List env files (excluding current.env symlink and example.env)
	echo "  Profiles:"
	b_profile_count=0
	for b_env in ~/.config/proxmox-sh/*.env; do
		b_name="$(basename "${b_env}")"
		if test "${b_name}" = "*.env"; then
			fn_log_warn "no .env files found in ~/.config/proxmox-sh/"
			return
		fi
		if test "${b_name}" = "current.env"; then
			continue
		fi
		if test "${b_name}" = "example.env"; then
			continue
		fi
		b_profile_count=$((b_profile_count + 1))
		printf '    - %s\n' "${b_name}"
	done

	if test "${b_profile_count}" -eq 0; then
		fn_log_warn "no profiles found (only example.env)"
		return
	fi

	# Check current.env symlink
	if ! test -e ~/.config/proxmox-sh/current.env; then
		fn_log_warn "no current.env - run: env-switch proxmox-sh <profile>"
		return
	fi
	if ! test -L ~/.config/proxmox-sh/current.env; then
		fn_log_warn "current.env is a regular file, not a symlink - env-switch expects a symlink"
		return
	fi

	# shellcheck disable=SC2012
	b_current_target="$(ls -l ~/.config/proxmox-sh/current.env | sed 's;.*/;;')"
	fn_log_ok "current.env -> ${b_current_target}"

	# Validate current env contents
	fn_validate_env_file ~/.config/proxmox-sh/current.env
}

fn_validate_env_file() {
	b_env_file="${1}"

	# Source to check variables
	# shellcheck disable=SC1090
	(
		. "${b_env_file}" || true

		echo "  Config:"
		printf '    PROXMOX_HOST=%s\n' "${PROXMOX_HOST:-<unset>}"
		printf '    PROXMOX_TARGET_NODE=%s\n' "${PROXMOX_TARGET_NODE:-<unset>}"
		printf '    PROXMOX_ID_PREFIX=%s\n' "${PROXMOX_ID_PREFIX:-<unset>}"
		printf '    PROXMOX_RESOURCE_POOL=%s\n' "${PROXMOX_RESOURCE_POOL:-<unset>}"
		if test -n "${PROXMOX_VNET:-}"; then
			printf '    PROXMOX_VNET=%s\n' "${PROXMOX_VNET}"
		elif test -n "${PROXMOX_BRIDGE:-}"; then
			printf '    PROXMOX_BRIDGE=%s\n' "${PROXMOX_BRIDGE}"
		fi
		printf '    PROXMOX_SEARCH_DOMAIN=%s\n' "${PROXMOX_SEARCH_DOMAIN:-<unset>}"
		printf '    DIRECT_IP_DOMAIN=%s\n' "${DIRECT_IP_DOMAIN:-<unset>}"
		printf '    PROXMOX_TEMPLATE_DEFAULT=%s\n' "${PROXMOX_TEMPLATE_DEFAULT:-<unset>}"

		# Check required vars
		if test -z "${PROXMOX_HOST:-}"; then
			echo "  [ERROR] PROXMOX_HOST not set" >&2
		fi
		if test -z "${PROXMOX_TOKEN_ID:-}"; then
			echo "  [ERROR] PROXMOX_TOKEN_ID not set" >&2
		fi
		if test -z "${PROXMOX_TOKEN_SECRET:-}"; then
			echo "  [ERROR] PROXMOX_TOKEN_SECRET not set" >&2
		fi
		if test -n "${PROXMOX_TOKEN_ID:-}" && test -n "${PROXMOX_TOKEN_SECRET:-}"; then
			echo "  [OK] PROXMOX_TOKEN_ID and PROXMOX_TOKEN_SECRET are set"
		fi
	)
}

# ----------------------------------------
# Section 4: API connectivity
# ----------------------------------------
fn_check_api() {
	fn_log_section "API Connectivity"

	if ! test -e ~/.config/proxmox-sh/current.env; then
		fn_log_warn "skipping API checks - no current.env"
		return
	fi

	# shellcheck disable=SC1090
	. ~/.config/proxmox-sh/current.env || true

	if test -z "${PROXMOX_HOST:-}" ||
		test -z "${PROXMOX_TOKEN_ID:-}" ||
		test -z "${PROXMOX_TOKEN_SECRET:-}"; then
		fn_log_warn "skipping API checks - missing HOST/TOKEN vars"
		return
	fi

	b_auth="Authorization: PVEAPIToken=${PROXMOX_TOKEN_ID}=${PROXMOX_TOKEN_SECRET}"
	b_base_url="https://${PROXMOX_HOST}/api2/json"
	b_curl="curl --max-time 10 --fail-with-body -sSL"

	# Test basic connectivity
	if ! b_version="$(${b_curl} -H "${b_auth}" "${b_base_url}/version" 2>&1)"; then
		fn_log_err "cannot reach Proxmox API at ${PROXMOX_HOST}"
		echo "  Response: ${b_version}" >&2
		return
	fi

	b_pve_version="$(echo "${b_version}" | jq -r '.data.version // "unknown"')"
	fn_log_ok "API reachable - Proxmox VE ${b_pve_version}"

	# Check token permissions
	fn_check_permissions "${b_curl}" "${b_auth}" "${b_base_url}"
}

# ----------------------------------------
# Section 5: Token permissions
# ----------------------------------------
fn_check_permissions() {
	b_curl="${1}"
	b_auth="${2}"
	b_base_url="${3}"

	fn_log_section "Token Permissions"

	if ! b_perms="$(${b_curl} -H "${b_auth}" "${b_base_url}/access/permissions" 2>&1)"; then
		fn_log_warn "cannot query token permissions"
		return
	fi

	# Show paths where the token has at least one granted permission
	b_granted="$(echo "${b_perms}" | jq -r '
		[.data | to_entries[]
			| select(.value | to_entries | map(select(.value == 1)) | length > 0)
			| {
				path: .key,
				perms: [.value | to_entries[] | select(.value == 1) | .key] | sort
			}
		] | sort_by(.path)
	')"

	b_path_count="$(echo "${b_granted}" | jq 'length')"
	if test "${b_path_count}" -eq 0; then
		fn_log_warn "token has no granted permissions on any path"
		return
	fi

	fn_log_ok "token has grants on ${b_path_count} paths"

	# Group by path prefix for readable output
	echo ""
	echo "  Pools:"
	echo "${b_granted}" | jq -r '.[] | select(.path | startswith("/pool/")) | "    \(.path)  \(.perms | join(", "))"'

	echo ""
	echo "  Storage:"
	echo "${b_granted}" | jq -r '.[] | select(.path | startswith("/storage/")) | "    \(.path)  \(.perms | join(", "))"'

	echo ""
	echo "  SDN:"
	echo "${b_granted}" | jq -r '.[] | select(.path | startswith("/sdn/")) | "    \(.path)  \(.perms | join(", "))"'

	echo ""
	echo "  Nodes:"
	echo "${b_granted}" | jq -r '.[] | select(.path | startswith("/nodes")) | "    \(.path)  \(.perms | join(", "))"'

	# Check for common required permissions
	b_has_pool_allocate="$(echo "${b_granted}" | jq '[.[] | select(.path | startswith("/pool/")) | .perms[] | select(. == "Pool.Allocate")] | length')"
	b_has_vm_allocate="$(echo "${b_granted}" | jq '[.[] | select(.path | startswith("/pool/")) | .perms[] | select(. == "VM.Allocate")] | length')"
	b_has_datastore="$(echo "${b_granted}" | jq '[.[] | select(.path | startswith("/storage/")) | .perms[] | select(. == "Datastore.AllocateSpace")] | length')"

	echo ""
	if test "${b_has_pool_allocate}" -gt 0; then
		fn_log_ok "Pool.Allocate granted (can add VMs to pools)"
	else
		fn_log_warn "Pool.Allocate not granted on any pool"
	fi
	if test "${b_has_vm_allocate}" -gt 0; then
		fn_log_ok "VM.Allocate granted (can create VMs)"
	else
		fn_log_warn "VM.Allocate not granted on any pool"
	fi
	if test "${b_has_datastore}" -gt 0; then
		fn_log_ok "Datastore.AllocateSpace granted (can allocate storage)"
	else
		fn_log_warn "Datastore.AllocateSpace not granted on any storage"
	fi
}

# ----------------------------------------
# Summary
# ----------------------------------------
fn_summary() {
	fn_log_section "Summary"

	if test "${g_exit_code}" -eq 0; then
		echo "  All checks passed. Ready to use proxmox-sh."
		echo "  Run proxmox-sh-resources for infrastructure details."
	elif test "${g_exit_code}" -eq 2; then
		echo "  Passed with warnings. Review [WARN] items above."
	else
		echo "  FAILED. Fix [ERROR] items above before proceeding."
	fi
	echo ""
}

main() {
	echo "proxmox-sh-doctor"
	echo "================="

	fn_check_deps
	fn_check_proxmox_sh
	fn_check_env_files
	fn_check_api
	fn_summary

	return "${g_exit_code}"
}

main "$@"
