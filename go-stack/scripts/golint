#!/bin/sh
# Run the full Go pre-commit lint sequence.
# go vet excludes sqlc-generated packages (internal/v1db, internal/v2db) —
# those are ephemeral and regenerated by scripts/sqlc-generate.
set -e
set -u

go fmt ./...
goimports -w .
go fix ./...

b_out="$(go list ./... | grep -Ev 'internal/v[12]db' | xargs go vet 2>&1 | grep -Ev 'internal/v[12]db/' || true)"
if test -n "$b_out"; then
    printf '%s\n' "$b_out" >&2
    exit 1
fi
