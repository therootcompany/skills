#!/bin/sh
# Run the full Go pre-commit lint sequence across all modules in a monorepo.
#
# Finds every go.mod, sorts deepest-first, and runs fmt + imports + fix + vet + tidy
# in each module directory. Skips worktrees, vendor, node_modules, and agent dirs.
#
# Usage:
#   scripts/golint [root-dir]
#
# Exit codes:
#   0  all modules clean
#   1  one or more modules had lint or tidy errors
set -e
set -u

g_root="${1:-.}"

# Directories to skip (worktrees, agent scratch, vendored deps)
g_prune='-path */.claude/* -o -path */worktrees.git/* -o -path */agents/* -o -path */vendor/* -o -path */node_modules/*'

# Find all go.mod files, excluding noise directories
g_mods="$(
    eval "find \"$g_root\" \\( $g_prune \\) -prune -o -name go.mod -print"
)"

# Sort by slash count descending (depth-first), then alphabetically
g_dirs="$(
    echo "$g_mods" |
        while IFS= read -r b_mod; do
            test -n "$b_mod" || continue
            dirname "$b_mod"
        done |
        awk -F/ '{ print NF, $0 }' |
        sort -t' ' -k1,1nr -k2,2 |
        cut -d' ' -f2-
)"

g_failed=""

fn_lint_module() {
    a_dir="$1"

    # fmt
    go fmt ./... >/dev/null 2>&1

    # goimports (skip if not installed)
    if command -v goimports >/dev/null 2>&1; then
        goimports -w .
    fi

    # fix
    go fix ./... >/dev/null 2>&1

    # vet — exclude sqlc-generated packages
    b_out="$(go list ./... 2>/dev/null | grep -Ev 'internal/v[12]db' | xargs go vet 2>&1 | grep -Ev 'internal/v[12]db/' || true)"
    if test -n "$b_out"; then
        printf '%s\n' "$b_out" >&2
        return 1
    fi

    # tidy
    go mod tidy 2>&1
}

echo "$g_dirs" |
    while IFS= read -r b_dir; do
        test -n "$b_dir" || continue
        printf '  lint %s\n' "$b_dir"
        if ! (cd "$b_dir" && fn_lint_module "$b_dir"); then
            printf '  FAIL %s\n' "$b_dir" >&2
            g_failed="${g_failed} ${b_dir}"
        fi
    done

if test -n "$g_failed"; then
    printf '\nFailed:\n' >&2
    for b_dir in $g_failed; do
        printf '  %s\n' "$b_dir" >&2
    done
    exit 1
fi
